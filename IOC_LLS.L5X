<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<RSLogix5000Content SchemaRevision="1.0" SoftwareRevision="33.00" TargetName="IOC_LLS" TargetType="AddOnInstructionDefinition" ContainsContext="true" ExportDate="2026-07-15T20:38:20.000Z" ExportOptions="References DecoratedData ForceProtectedEncoding AllProjDocTrans">
<Controller Use="Context" Name="IOC_LLS_Context">
<DataTypes Use="Context">
<DataType Name="IOC_LLS_Unit" Family="NoFamily" Class="User">
<Description>
<![CDATA[Per-unit interface for IOC_LLS. One element per managed unit.]]>
</Description>
<Members>
<Member Name="Cfg_Prio" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Motor priority in list (0-31). Higher = starts first.]]>
</Description>
</Member>
<Member Name="Cfg_Pref" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Preference tiebreaker (0-31). Higher = starts first when Prio equal.]]>
</Description>
</Member>
<Member Name="ZZZZZZZZZZIOC_LLS_Un1" DataType="SINT" Dimension="0" Radix="Decimal" Hidden="true" ExternalAccess="Read/Write"/>
<Member Name="Cfg_Disable" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="0" ExternalAccess="Read/Write">
<Description>
<![CDATA[1 = Disable this unit (excluded from ranking)]]>
</Description>
</Member>
<Member Name="Sts_Available" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="1" ExternalAccess="Read/Write">
<Description>
<![CDATA[Input to LLS: 1 = unit ready to run (Program mode, no faults)]]>
</Description>
</Member>
<Member Name="Sts_Running" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="2" ExternalAccess="Read/Write">
<Description>
<![CDATA[Input to LLS: 1 = unit confirmed running]]>
</Description>
</Member>
<Member Name="Sts_Starting" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="3" ExternalAccess="Read/Write">
<Description>
<![CDATA[Input to LLS: 1 = unit in start sequence]]>
</Description>
</Member>
<Member Name="Sts_Stopping" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="4" ExternalAccess="Read/Write">
<Description>
<![CDATA[Input to LLS: 1 = unit in stop sequence]]>
</Description>
</Member>
<Member Name="Sts_Stopped" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="5" ExternalAccess="Read/Write">
<Description>
<![CDATA[Input to LLS: 1 = unit confirmed stopped]]>
</Description>
</Member>
<Member Name="PCmd_Start" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="6" ExternalAccess="Read/Write">
<Description>
<![CDATA[Output from LLS: 1 = command unit to start]]>
</Description>
</Member>
<Member Name="PCmd_Stop" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZIOC_LLS_Un1" BitNumber="7" ExternalAccess="Read/Write">
<Description>
<![CDATA[Output from LLS: 1 = command unit to stop]]>
</Description>
</Member>
<Member Name="Val_Rank" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Output from LLS: 1=Lead, 2=Lag1, ..., 0=disabled/unavailable]]>
</Description>
</Member>
</Members>
</DataType>
</DataTypes>
<AddOnInstructionDefinitions Use="Context">
<AddOnInstructionDefinition Use="Target" Name="IOC_LLS" Revision="1.0" Class="Standard" ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2026-07-15T20:38:20.000Z" CreatedBy="Claude" EditedDate="2026-07-15T20:38:20.000Z" EditedBy="Claude" SoftwareRevision="v33.00">
<Description>
<![CDATA[Lead/Lag/Standby controller for up to 12 units (valve+VSD, etc.).]]>
</Description>
<Parameters>
    <Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
      <Description>
        <![CDATA[Enable Input - System Defined Parameter]]>
      </Description>
    </Parameter>
    <Parameter Name="EnableOut" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
      <Description>
        <![CDATA[Enable Output - System Defined Parameter]]>
      </Description>
    </Parameter>
    <Parameter Name="Cmd_Prog" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Momentary - command Program mode]]>
      </Description>
    </Parameter>
    <Parameter Name="Cmd_Oper" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Momentary - command Operator mode (wins over Cmd_Prog)]]>
      </Description>
    </Parameter>
    <Parameter Name="PCmd_Start" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Program command Start system (momentary)]]>
      </Description>
    </Parameter>
    <Parameter Name="PCmd_Stop" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Program command Stop system (momentary)]]>
      </Description>
    </Parameter>
    <Parameter Name="PCmd_Reset" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Program command Reset alarms (momentary)]]>
      </Description>
    </Parameter>
    <Parameter Name="PCmd_Rotate" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Program command Rotate lead (momentary; gated by Cfg_AllowRotate)]]>
      </Description>
    </Parameter>
    <Parameter Name="OCmd_Start" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Operator command Start system (momentary)]]>
      </Description>
    </Parameter>
    <Parameter Name="OCmd_Stop" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Operator command Stop system (momentary)]]>
      </Description>
    </Parameter>
    <Parameter Name="OCmd_Reset" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Operator command Reset alarms (momentary)]]>
      </Description>
    </Parameter>
    <Parameter Name="OCmd_Rotate" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Operator command Rotate lead (momentary)]]>
      </Description>
    </Parameter>
    <Parameter Name="PSet_Demand" TagType="Base" DataType="DINT" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Number of units to run (0..Cfg_MaxDemand). Clamped internally.]]>
      </Description>
    </Parameter>
    <Parameter Name="Inp_IntlkOK" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1=Interlock OK. Live: dropping this trips the whole system (Sts_IntlkTrip).]]>
      </Description>
    </Parameter>
    <Parameter Name="Inp_PermOK" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1=Permissive OK. Only gates new Start commands; does not shut down a running system.]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_ProgPwrUp" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1 = default to Program mode on power-up]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_NumUnits" TagType="Base" DataType="DINT" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Number of units managed (1..12). Must match size of Ref_Units.]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_MinDemand" TagType="Base" DataType="DINT" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Minimum PSet_Demand allowed (0..Cfg_NumUnits)]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_MaxDemand" TagType="Base" DataType="DINT" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Maximum PSet_Demand allowed (0..Cfg_NumUnits)]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_StartDelay" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Delay between successive unit starts (sec, 0=no stagger)]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_StopDelay" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Delay between successive unit stops (sec, 0=no stagger)]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_AllowRotate" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1 = Enable rotation via PCmd_Rotate / Cfg_RotateOnStop]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_RotateOnStop" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1 = Auto-rotate on system Stop (rising edge of NOT Sts_Running)]]>
      </Description>
    </Parameter>
    <Parameter Name="Cfg_HasIntlkTripAlm" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1 = Enable IntlkTrip alarm latching (live IntlkTrip always trips regardless)]]>
      </Description>
    </Parameter>
    <Parameter Name="Ref_Units" TagType="Base" DataType="IOC_LLS_Unit" Dimensions="2" Usage="InOut" Required="true" Visible="true" Constant="false">
      <Description>
        <![CDATA[Array of unit interfaces (size must be >= Cfg_NumUnits, max 12)]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_NotRdy" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Master not-ready (Alm_CfgErr latched)]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Available" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Sts_Prog AND NOT Sts_NotRdy]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Ready" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[NOT Alm_CfgErr]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_RdyReset" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1 = Reset would clear a latched alarm]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Prog" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1 = Program mode active]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Oper" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[1 = Operator mode active]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Running" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[System commanded running (control mode, not physical motion)]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Stopped" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[System commanded stopped AND all units stopped]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Stopping" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[System commanded stopped but units still running]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Increasing" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[System running, actual count < demand (units still starting)]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_Decreasing" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[System running, actual count > demand (units still stopping)]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_CfgErr" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Live: Cfg_NumUnits out of range 1..12]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_IntlkTrip" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Live: NOT Inp_IntlkOK - system tripped by interlock]]>
      </Description>
    </Parameter>
    <Parameter Name="Val_Demand" TagType="Base" DataType="DINT" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Current effective demand (units the LLS is asking to run)]]>
      </Description>
    </Parameter>
    <Parameter Name="Val_NumRunning" TagType="Base" DataType="DINT" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Count of units currently in Sts_Running]]>
      </Description>
    </Parameter>
    <Parameter Name="Val_NumAvailable" TagType="Base" DataType="DINT" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Count of eligible units (Available AND NOT Disabled)]]>
      </Description>
    </Parameter>
    <Parameter Name="Val_RotateOffset" TagType="Base" DataType="DINT" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Current rotation offset (0..Cfg_NumUnits-1)]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_UnitAvail" TagType="Base" DataType="DINT" Usage="Output" Radix="Binary" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Bitmask: bit i = unit i is eligible]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_UnitRunning" TagType="Base" DataType="DINT" Usage="Output" Radix="Binary" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Bitmask: bit i = unit i is running]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_UnitStarting" TagType="Base" DataType="DINT" Usage="Output" Radix="Binary" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Bitmask: bit i = unit i is starting]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_UnitStopping" TagType="Base" DataType="DINT" Usage="Output" Radix="Binary" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Bitmask: bit i = unit i is stopping]]>
      </Description>
    </Parameter>
    <Parameter Name="Sts_UnitStopped" TagType="Base" DataType="DINT" Usage="Output" Radix="Binary" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Bitmask: bit i = unit i is stopped]]>
      </Description>
    </Parameter>
    <Parameter Name="Alm_CfgErr" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Latched Cfg_NumUnits out-of-range (needs reset)]]>
      </Description>
    </Parameter>
    <Parameter Name="Alm_IntlkTrip" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read/Write">
      <Description>
        <![CDATA[Latched IntlkTrip (needs reset; gated by Cfg_HasIntlkTripAlm)]]>
      </Description>
    </Parameter>
</Parameters>
<LocalTags>
    <LocalTag Name="Wrk_ModeAuto" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Active mode (1=Program, 0=Operator)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevModeAuto" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Previous-scan mode]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevPCmdStart" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Edge detect prev PCmd_Start]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevPCmdStop" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Edge detect prev PCmd_Stop]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevPCmdRotate" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Edge detect prev PCmd_Rotate]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevOCmdStart" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Edge detect prev OCmd_Start]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevOCmdStop" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Edge detect prev OCmd_Stop]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevOCmdRotate" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Edge detect prev OCmd_Rotate]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_SrcCmdStartEdge" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Source-selected Start edge]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_SrcCmdStopEdge" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Source-selected Stop edge]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_SrcCmdRotateEdge" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Source-selected Rotate edge]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_SysRunning" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[System start/stop latch]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevSysRunning" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Previous SysRunning (for stop-edge rotation)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_SysStoppedEdge" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[System just stopped (falling edge of SysRunning)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_ResetAlm" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Reset pulse (one scan)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_NotRdy" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Master not-ready]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_RotateOffset" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Cyclic rotation offset (0..Cfg_NumUnits-1)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_I" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[FOR loop index]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_J" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[FOR loop inner index]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_Rank" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Rank scratch]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_ClampedNumUnits" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Cfg_NumUnits clamped to 0..12 for iteration]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_UnitEligible" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Per-unit eligibility bitmask (bit i = unit i eligible)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_UnitPos" DataType="DINT" Dimensions="12" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Per-unit cyclic rotation position]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_NumEligible" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Count of eligible units this scan]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_NumRunning" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Count of running units this scan]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_TargetNum" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Clamped final target (0..NumEligible)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_EffectiveTarget" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Reported count of units currently committed in Wrk_CmdRunMask]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_StaggerTmr" DataType="FBD_TIMER" ExternalAccess="None">
      <Description>
        <![CDATA[Stagger delay timer (dynamic PRE)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_StaggerTmrDNEdge" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Rising edge of Wrk_StaggerTmr.DN]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PrevStaggerTmrDN" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Previous-scan value of Wrk_StaggerTmr.DN]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_CmdRunMask" DataType="DINT" Radix="Binary" ExternalAccess="None">
      <Description>
        <![CDATA[Persistent per-unit committed-to-run set (bit i = unit i). Migrates
toward Wrk_DesiredRunMask one unit at a time, staggered by
Cfg_StartDelay/Cfg_StopDelay, regardless of whether the overall count
changes - so a fault-driven promotion staggers in exactly like a
fresh start.]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_DesiredRunMask" DataType="DINT" Radix="Binary" ExternalAccess="None">
      <Description>
        <![CDATA[Units that should be running this scan (Val_Rank 1..Wrk_TargetNum)]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PendingAdd" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Index of the single highest-priority unit awaiting start, or -1]]>
      </Description>
    </LocalTag>
    <LocalTag Name="Wrk_PendingRemove" DataType="DINT" Radix="Decimal" ExternalAccess="None">
      <Description>
        <![CDATA[Index of the single lowest-priority committed unit awaiting stop, or -1]]>
      </Description>
    </LocalTag>
</LocalTags>
<Routines>
<Routine Name="Logic" Type="ST">
<STContent>
      <Line Number="0"><![CDATA[(*]]></Line>
      <Line Number="1"><![CDATA[=============================================================================]]></Line>
      <Line Number="2"><![CDATA[IOC_LLS - Lead/Lag/Standby controller for up to 12 units]]></Line>
      <Line Number="3"><![CDATA[=============================================================================]]></Line>
      <Line Number="4"><![CDATA[Each unit is an external black box (typically a valve + VSD pair driven by]]></Line>
      <Line Number="5"><![CDATA[your own sequencing ladder). This AOI ranks units and issues PCmd_Start /]]></Line>
      <Line Number="6"><![CDATA[PCmd_Stop through the Ref_Units UDT array; it does NOT drive valves or]]></Line>
      <Line Number="7"><![CDATA[drives directly.]]></Line>
      <Line Number="8"><![CDATA[]]></Line>
      <Line Number="9"><![CDATA[Per-unit wiring (user's ladder):]]></Line>
      <Line Number="10"><![CDATA[  Copy INTO Ref_Units[i].Sts_*:]]></Line>
      <Line Number="11"><![CDATA[    Sts_Available = valve.Sts_Available AND vsd.Sts_Available]]></Line>
      <Line Number="12"><![CDATA[    Sts_Running   = valve.Sts_Opened AND vsd.Sts_RunningFwd]]></Line>
      <Line Number="13"><![CDATA[    Sts_Starting  = user's start-sequence flag]]></Line>
      <Line Number="14"><![CDATA[    Sts_Stopping  = user's stop-sequence flag]]></Line>
      <Line Number="15"><![CDATA[    Sts_Stopped   = valve.Sts_Closed AND vsd.Sts_Stopped]]></Line>
      <Line Number="16"><![CDATA[]]></Line>
      <Line Number="17"><![CDATA[  Act on Ref_Units[i].PCmd_Start / PCmd_Stop:]]></Line>
      <Line Number="18"><![CDATA[    PCmd_Start rising -> begin start sequence (open valve, wait, start VSD)]]></Line>
      <Line Number="19"><![CDATA[    PCmd_Stop rising  -> begin stop sequence (stop VSD, wait, close valve)]]></Line>
      <Line Number="20"><![CDATA[    On valve or VSD fault: user's ladder drops Sts_Available]]></Line>
      <Line Number="21"><![CDATA[]]></Line>
      <Line Number="22"><![CDATA[Ranking:]]></Line>
      <Line Number="23"><![CDATA[  Sticky: currently-running units rank ahead of idle ones, so a unit
  that returns to available does not bump one already running to cover
  for it. Within each tier: Cfg_Prio (0-31) desc, then cyclic rotation
  position, then Cfg_Pref desc, then unit index.]]></Line>
      <Line Number="24"><![CDATA[  Only Sts_Available AND NOT Cfg_Disable units are ranked.]]></Line>
      <Line Number="25"><![CDATA[  Val_Rank = 0 for unavailable / disabled units.]]></Line>
      <Line Number="26"><![CDATA[]]></Line>
      <Line Number="27"><![CDATA[Demand:]]></Line>
      <Line Number="28"><![CDATA[  PSet_Demand clamped to [Cfg_MinDemand, Cfg_MaxDemand] and to number of]]></Line>
      <Line Number="29"><![CDATA[  eligible units. Val_Demand = current effective demand (Wrk_EffectiveTarget).]]></Line>
      <Line Number="30"><![CDATA[  Cfg_StartDelay / Cfg_StopDelay stagger between successive changes.]]></Line>
      <Line Number="31"><![CDATA[]]></Line>
      <Line Number="32"><![CDATA[Rotation:]]></Line>
      <Line Number="33"><![CDATA[  PCmd_Rotate (edge) or Cfg_RotateOnStop (on system stop) advances the]]></Line>
      <Line Number="34"><![CDATA[  cyclic offset by 1. Cfg_AllowRotate gates rotation entirely.]]></Line>
      <Line Number="35"><![CDATA[]]></Line>
      <Line Number="36"><![CDATA[Auto-promote:]]></Line>
      <Line Number="37"><![CDATA[  Handled naturally by ranking - when a running unit's Sts_Available drops,]]></Line>
      <Line Number="38"><![CDATA[  Val_Rank becomes 0 and the next-ranked standby inherits its slot. Because
  ranking is sticky, that standby keeps running even after the original
  unit becomes available again - it only gives the slot back on rotation.]]></Line>
      <Line Number="39"><![CDATA[=============================================================================]]></Line>
      <Line Number="40"><![CDATA[*)]]></Line>
      <Line Number="41"><![CDATA[]]></Line>
      <Line Number="42"><![CDATA[]]></Line>
      <Line Number="43"><![CDATA[(*]]></Line>
      <Line Number="44"><![CDATA[========================================]]></Line>
      <Line Number="45"><![CDATA[Mode select]]></Line>
      <Line Number="46"><![CDATA[========================================]]></Line>
      <Line Number="47"><![CDATA[*)]]></Line>
      <Line Number="48"><![CDATA[IF Cmd_Oper THEN]]></Line>
      <Line Number="49"><![CDATA[    Wrk_ModeAuto := 0;]]></Line>
      <Line Number="50"><![CDATA[ELSIF Cmd_Prog THEN]]></Line>
      <Line Number="51"><![CDATA[    Wrk_ModeAuto := 1;]]></Line>
      <Line Number="52"><![CDATA[END_IF;]]></Line>
      <Line Number="53"><![CDATA[]]></Line>
      <Line Number="54"><![CDATA[]]></Line>
      <Line Number="55"><![CDATA[(*]]></Line>
      <Line Number="56"><![CDATA[========================================]]></Line>
      <Line Number="57"><![CDATA[Command edge detection + source selection]]></Line>
      <Line Number="58"><![CDATA[========================================]]></Line>
      <Line Number="59"><![CDATA[*)]]></Line>
      <Line Number="60"><![CDATA[IF Wrk_ModeAuto THEN]]></Line>
      <Line Number="61"><![CDATA[    Wrk_SrcCmdStartEdge  := PCmd_Start  AND NOT Wrk_PrevPCmdStart;]]></Line>
      <Line Number="62"><![CDATA[    Wrk_SrcCmdStopEdge   := PCmd_Stop   AND NOT Wrk_PrevPCmdStop;]]></Line>
      <Line Number="63"><![CDATA[    Wrk_SrcCmdRotateEdge := PCmd_Rotate AND NOT Wrk_PrevPCmdRotate;]]></Line>
      <Line Number="64"><![CDATA[ELSE]]></Line>
      <Line Number="65"><![CDATA[    Wrk_SrcCmdStartEdge  := OCmd_Start  AND NOT Wrk_PrevOCmdStart;]]></Line>
      <Line Number="66"><![CDATA[    Wrk_SrcCmdStopEdge   := OCmd_Stop   AND NOT Wrk_PrevOCmdStop;]]></Line>
      <Line Number="67"><![CDATA[    Wrk_SrcCmdRotateEdge := OCmd_Rotate AND NOT Wrk_PrevOCmdRotate;]]></Line>
      <Line Number="68"><![CDATA[END_IF;]]></Line>
      <Line Number="69"><![CDATA[]]></Line>
      <Line Number="70"><![CDATA[Wrk_PrevPCmdStart  := PCmd_Start;]]></Line>
      <Line Number="71"><![CDATA[Wrk_PrevPCmdStop   := PCmd_Stop;]]></Line>
      <Line Number="72"><![CDATA[Wrk_PrevPCmdRotate := PCmd_Rotate;]]></Line>
      <Line Number="73"><![CDATA[Wrk_PrevOCmdStart  := OCmd_Start;]]></Line>
      <Line Number="74"><![CDATA[Wrk_PrevOCmdStop   := OCmd_Stop;]]></Line>
      <Line Number="75"><![CDATA[Wrk_PrevOCmdRotate := OCmd_Rotate;]]></Line>
      <Line Number="76"><![CDATA[]]></Line>
      <Line Number="77"><![CDATA[]]></Line>
      <Line Number="78"><![CDATA[(*]]></Line>
      <Line Number="79"><![CDATA[========================================]]></Line>
      <Line Number="80"><![CDATA[Live status mirror + master not-ready rollup]]></Line>
      <Line Number="81"><![CDATA[Live interlock (NOT Inp_IntlkOK) drops the system immediately.]]></Line>
      <Line Number="82"><![CDATA[Permissive (Inp_PermOK) only blocks new starts (see command latch below).]]></Line>
      <Line Number="83"><![CDATA[========================================]]></Line>
      <Line Number="84"><![CDATA[*)]]></Line>
      <Line Number="85"><![CDATA[Sts_IntlkTrip := NOT Inp_IntlkOK;]]></Line>
      <Line Number="86"><![CDATA[]]></Line>
      <Line Number="87"><![CDATA[Wrk_NotRdy :=]]></Line>
      <Line Number="88"><![CDATA[    Alm_CfgErr]]></Line>
      <Line Number="89"><![CDATA[    OR Sts_IntlkTrip]]></Line>
      <Line Number="90"><![CDATA[    OR Alm_IntlkTrip;]]></Line>
      <Line Number="91"><![CDATA[]]></Line>
      <Line Number="92"><![CDATA[]]></Line>
      <Line Number="93"><![CDATA[(*]]></Line>
      <Line Number="94"><![CDATA[========================================]]></Line>
      <Line Number="95"><![CDATA[System-level Start/Stop latch]]></Line>
      <Line Number="96"><![CDATA[Stop wins over Start. NotRdy forces Stop.]]></Line>
      <Line Number="97"><![CDATA[Start edge is gated by Inp_PermOK (permissive must be OK to start,]]></Line>
      <Line Number="98"><![CDATA[but does not shut down a system that's already running).]]></Line>
      <Line Number="99"><![CDATA[========================================]]></Line>
      <Line Number="100"><![CDATA[*)]]></Line>
      <Line Number="101"><![CDATA[IF Wrk_NotRdy THEN]]></Line>
      <Line Number="102"><![CDATA[    Wrk_SysRunning := 0;]]></Line>
      <Line Number="103"><![CDATA[ELSIF Wrk_SrcCmdStopEdge THEN]]></Line>
      <Line Number="104"><![CDATA[    Wrk_SysRunning := 0;]]></Line>
      <Line Number="105"><![CDATA[ELSIF Wrk_SrcCmdStartEdge AND Inp_PermOK THEN]]></Line>
      <Line Number="106"><![CDATA[    Wrk_SysRunning := 1;]]></Line>
      <Line Number="107"><![CDATA[END_IF;]]></Line>
      <Line Number="108"><![CDATA[]]></Line>
      <Line Number="109"><![CDATA[]]></Line>
      <Line Number="110"><![CDATA[(*]]></Line>
      <Line Number="111"><![CDATA[========================================]]></Line>
      <Line Number="112"><![CDATA[Self-clear PCmd / OCmd]]></Line>
      <Line Number="113"><![CDATA[========================================]]></Line>
      <Line Number="114"><![CDATA[*)]]></Line>
      <Line Number="115"><![CDATA[PCmd_Start  := 0;]]></Line>
      <Line Number="116"><![CDATA[PCmd_Stop   := 0;]]></Line>
      <Line Number="117"><![CDATA[PCmd_Rotate := 0;]]></Line>
      <Line Number="118"><![CDATA[OCmd_Start  := 0;]]></Line>
      <Line Number="119"><![CDATA[OCmd_Stop   := 0;]]></Line>
      <Line Number="120"><![CDATA[OCmd_Rotate := 0;]]></Line>
      <Line Number="121"><![CDATA[]]></Line>
      <Line Number="122"><![CDATA[]]></Line>
      <Line Number="123"><![CDATA[(*]]></Line>
      <Line Number="124"><![CDATA[========================================]]></Line>
      <Line Number="125"><![CDATA[Reset]]></Line>
      <Line Number="126"><![CDATA[========================================]]></Line>
      <Line Number="127"><![CDATA[*)]]></Line>
      <Line Number="128"><![CDATA[Wrk_ResetAlm := PCmd_Reset OR OCmd_Reset;]]></Line>
      <Line Number="129"><![CDATA[PCmd_Reset := 0;]]></Line>
      <Line Number="130"><![CDATA[OCmd_Reset := 0;]]></Line>
      <Line Number="131"><![CDATA[]]></Line>
      <Line Number="132"><![CDATA[]]></Line>
      <Line Number="133"><![CDATA[(*]]></Line>
      <Line Number="134"><![CDATA[========================================]]></Line>
      <Line Number="135"><![CDATA[Rotation handling]]></Line>
      <Line Number="136"><![CDATA[PCmd_Rotate edge OR (Cfg_RotateOnStop AND system just stopped) advances]]></Line>
      <Line Number="137"><![CDATA[Wrk_RotateOffset by 1 (mod Cfg_NumUnits). Gated by Cfg_AllowRotate.]]></Line>
      <Line Number="138"><![CDATA[========================================]]></Line>
      <Line Number="139"><![CDATA[*)]]></Line>
      <Line Number="140"><![CDATA[Wrk_SysStoppedEdge := (NOT Wrk_SysRunning) AND Wrk_PrevSysRunning;]]></Line>
      <Line Number="141"><![CDATA[]]></Line>
      <Line Number="142"><![CDATA[IF Cfg_AllowRotate AND Cfg_NumUnits > 0 THEN]]></Line>
      <Line Number="143"><![CDATA[    IF Wrk_SrcCmdRotateEdge THEN]]></Line>
      <Line Number="144"><![CDATA[        Wrk_RotateOffset := (Wrk_RotateOffset + 1) MOD Cfg_NumUnits;]]></Line>
      <Line Number="145"><![CDATA[    ELSIF Cfg_RotateOnStop AND Wrk_SysStoppedEdge THEN]]></Line>
      <Line Number="146"><![CDATA[        Wrk_RotateOffset := (Wrk_RotateOffset + 1) MOD Cfg_NumUnits;]]></Line>
      <Line Number="147"><![CDATA[    END_IF;]]></Line>
      <Line Number="148"><![CDATA[END_IF;]]></Line>
      <Line Number="149"><![CDATA[]]></Line>
      <Line Number="150"><![CDATA[Wrk_PrevSysRunning := Wrk_SysRunning;]]></Line>
      <Line Number="151"><![CDATA[]]></Line>
      <Line Number="152"><![CDATA[]]></Line>
      <Line Number="153"><![CDATA[(*]]></Line>
      <Line Number="154"><![CDATA[========================================]]></Line>
      <Line Number="155"><![CDATA[Config check (Cfg_NumUnits must be 1..12)]]></Line>
      <Line Number="156"><![CDATA[========================================]]></Line>
      <Line Number="157"><![CDATA[*)]]></Line>
      <Line Number="158"><![CDATA[Sts_CfgErr := (Cfg_NumUnits < 1) OR (Cfg_NumUnits > 12);]]></Line>
      <Line Number="159"><![CDATA[]]></Line>
      <Line Number="160"><![CDATA[IF Wrk_ResetAlm THEN]]></Line>
      <Line Number="161"><![CDATA[    Alm_CfgErr := 0;]]></Line>
      <Line Number="162"><![CDATA[ELSIF Sts_CfgErr THEN]]></Line>
      <Line Number="163"><![CDATA[    Alm_CfgErr := 1;]]></Line>
      <Line Number="164"><![CDATA[END_IF;]]></Line>
      <Line Number="165"><![CDATA[]]></Line>
      <Line Number="166"><![CDATA[]]></Line>
      <Line Number="167"><![CDATA[(*]]></Line>
      <Line Number="168"><![CDATA[========================================]]></Line>
      <Line Number="169"><![CDATA[Latched interlock alarm - only latches if Cfg_HasIntlkTripAlm.]]></Line>
      <Line Number="170"><![CDATA[Live Sts_IntlkTrip always drops the system regardless of Cfg.]]></Line>
      <Line Number="171"><![CDATA[========================================]]></Line>
      <Line Number="172"><![CDATA[*)]]></Line>
      <Line Number="173"><![CDATA[IF Wrk_ResetAlm THEN]]></Line>
      <Line Number="174"><![CDATA[    Alm_IntlkTrip := 0;]]></Line>
      <Line Number="175"><![CDATA[ELSIF Sts_IntlkTrip AND Cfg_HasIntlkTripAlm THEN]]></Line>
      <Line Number="176"><![CDATA[    Alm_IntlkTrip := 1;]]></Line>
      <Line Number="177"><![CDATA[END_IF;]]></Line>
      <Line Number="178"><![CDATA[]]></Line>
      <Line Number="179"><![CDATA[]]></Line>
      <Line Number="180"><![CDATA[(*]]></Line>
      <Line Number="181"><![CDATA[========================================]]></Line>
      <Line Number="182"><![CDATA[Per-unit eligibility and cyclic position]]></Line>
      <Line Number="183"><![CDATA[Iterating over up to Cfg_NumUnits (clamped to 12).]]></Line>
      <Line Number="184"><![CDATA[========================================]]></Line>
      <Line Number="185"><![CDATA[*)]]></Line>
      <Line Number="186"><![CDATA[Wrk_ClampedNumUnits := Cfg_NumUnits;]]></Line>
      <Line Number="187"><![CDATA[IF Wrk_ClampedNumUnits < 0 THEN]]></Line>
      <Line Number="188"><![CDATA[    Wrk_ClampedNumUnits := 0;]]></Line>
      <Line Number="189"><![CDATA[END_IF;]]></Line>
      <Line Number="190"><![CDATA[IF Wrk_ClampedNumUnits > 12 THEN]]></Line>
      <Line Number="191"><![CDATA[    Wrk_ClampedNumUnits := 12;]]></Line>
      <Line Number="192"><![CDATA[END_IF;]]></Line>
      <Line Number="193"><![CDATA[]]></Line>
      <Line Number="194"><![CDATA[Wrk_NumEligible := 0;]]></Line>
      <Line Number="195"><![CDATA[Wrk_UnitEligible := 0;]]></Line>
      <Line Number="196"><![CDATA[FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO]]></Line>
      <Line Number="197"><![CDATA[    IF Ref_Units[Wrk_I].Sts_Available AND (NOT Ref_Units[Wrk_I].Cfg_Disable) THEN]]></Line>
      <Line Number="198"><![CDATA[        Wrk_UnitEligible.[Wrk_I] := 1;]]></Line>
      <Line Number="199"><![CDATA[        Wrk_UnitPos[Wrk_I] := (Wrk_I + Wrk_ClampedNumUnits - Wrk_RotateOffset) MOD Wrk_ClampedNumUnits;]]></Line>
      <Line Number="200"><![CDATA[        Wrk_NumEligible := Wrk_NumEligible + 1;]]></Line>
      <Line Number="201"><![CDATA[    ELSE]]></Line>
      <Line Number="202"><![CDATA[        Wrk_UnitEligible.[Wrk_I] := 0;]]></Line>
      <Line Number="203"><![CDATA[        Wrk_UnitPos[Wrk_I] := 0;]]></Line>
      <Line Number="204"><![CDATA[        Ref_Units[Wrk_I].Val_Rank := 0;]]></Line>
      <Line Number="205"><![CDATA[    END_IF;]]></Line>
      <Line Number="206"><![CDATA[END_FOR;]]></Line>
      <Line Number="207"><![CDATA[]]></Line>
      <Line Number="208"><![CDATA[]]></Line>
      <Line Number="209"><![CDATA[(*]]></Line>
      <Line Number="210"><![CDATA[========================================]]></Line>
      <Line Number="211"><![CDATA[Rank each eligible unit]]></Line>
      <Line Number="212"><![CDATA[For unit i, rank = 1 + count of eligible units j that outrank i.]]></Line>
      <Line Number="213"><![CDATA[Ordering: Sts_Running desc (sticky tier - running units always outrank
idle ones so a returning unit can't bump one already covering for it),
then within tier: Cfg_Prio desc, Wrk_UnitPos asc, Cfg_Pref desc, index asc.]]></Line>
      <Line Number="214"><![CDATA[========================================]]></Line>
      <Line Number="215"><![CDATA[*)]]></Line>
      <Line Number="216"><![CDATA[FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO]]></Line>
      <Line Number="217"><![CDATA[    IF Wrk_UnitEligible.[Wrk_I] THEN]]></Line>
      <Line Number="218"><![CDATA[        Wrk_Rank := 1;]]></Line>
      <Line Number="219"><![CDATA[        FOR Wrk_J := 0 TO Wrk_ClampedNumUnits - 1 DO]]></Line>
      <Line Number="220"><![CDATA[            IF (Wrk_J <> Wrk_I) AND Wrk_UnitEligible.[Wrk_J] THEN]]></Line>
      <Line Number="221"><![CDATA[                IF Ref_Units[Wrk_J].Sts_Running AND NOT Ref_Units[Wrk_I].Sts_Running THEN
                    Wrk_Rank := Wrk_Rank + 1;
                ELSIF NOT (Ref_Units[Wrk_J].Sts_Running XOR Ref_Units[Wrk_I].Sts_Running) THEN
                    IF Ref_Units[Wrk_J].Cfg_Prio > Ref_Units[Wrk_I].Cfg_Prio THEN]]></Line>
      <Line Number="222"><![CDATA[                    Wrk_Rank := Wrk_Rank + 1;]]></Line>
      <Line Number="223"><![CDATA[                ELSIF Ref_Units[Wrk_J].Cfg_Prio = Ref_Units[Wrk_I].Cfg_Prio THEN]]></Line>
      <Line Number="224"><![CDATA[                    IF Wrk_UnitPos[Wrk_J] < Wrk_UnitPos[Wrk_I] THEN]]></Line>
      <Line Number="225"><![CDATA[                        Wrk_Rank := Wrk_Rank + 1;]]></Line>
      <Line Number="226"><![CDATA[                    ELSIF Wrk_UnitPos[Wrk_J] = Wrk_UnitPos[Wrk_I] THEN]]></Line>
      <Line Number="227"><![CDATA[                        IF Ref_Units[Wrk_J].Cfg_Pref > Ref_Units[Wrk_I].Cfg_Pref THEN]]></Line>
      <Line Number="228"><![CDATA[                            Wrk_Rank := Wrk_Rank + 1;]]></Line>
      <Line Number="229"><![CDATA[                        ELSIF Ref_Units[Wrk_J].Cfg_Pref = Ref_Units[Wrk_I].Cfg_Pref]]></Line>
      <Line Number="230"><![CDATA[                              AND Wrk_J < Wrk_I THEN]]></Line>
      <Line Number="231"><![CDATA[                            Wrk_Rank := Wrk_Rank + 1;]]></Line>
      <Line Number="232"><![CDATA[                        END_IF;]]></Line>
      <Line Number="233"><![CDATA[                    END_IF;]]></Line>
      <Line Number="234"><![CDATA[                END_IF;
                END_IF;]]></Line>
      <Line Number="235"><![CDATA[            END_IF;]]></Line>
      <Line Number="236"><![CDATA[        END_FOR;]]></Line>
      <Line Number="237"><![CDATA[        Ref_Units[Wrk_I].Val_Rank := Wrk_Rank;]]></Line>
      <Line Number="238"><![CDATA[    END_IF;]]></Line>
      <Line Number="239"><![CDATA[END_FOR;]]></Line>
      <Line Number="240"><![CDATA[]]></Line>
      <Line Number="241"><![CDATA[]]></Line>
      <Line Number="242"><![CDATA[(*]]></Line>
      <Line Number="243"><![CDATA[========================================]]></Line>
      <Line Number="244"><![CDATA[Compute target demand]]></Line>
      <Line Number="245"><![CDATA[Clamped to [Cfg_MinDemand, Cfg_MaxDemand], eligible count, and system state.]]></Line>
      <Line Number="246"><![CDATA[========================================]]></Line>
      <Line Number="247"><![CDATA[*)]]></Line>
      <Line Number="248"><![CDATA[Wrk_TargetNum := PSet_Demand;]]></Line>
      <Line Number="249"><![CDATA[IF Wrk_TargetNum < Cfg_MinDemand THEN]]></Line>
      <Line Number="250"><![CDATA[    Wrk_TargetNum := Cfg_MinDemand;]]></Line>
      <Line Number="251"><![CDATA[END_IF;]]></Line>
      <Line Number="252"><![CDATA[IF Wrk_TargetNum > Cfg_MaxDemand THEN]]></Line>
      <Line Number="253"><![CDATA[    Wrk_TargetNum := Cfg_MaxDemand;]]></Line>
      <Line Number="254"><![CDATA[END_IF;]]></Line>
      <Line Number="255"><![CDATA[IF Wrk_TargetNum > Wrk_NumEligible THEN]]></Line>
      <Line Number="256"><![CDATA[    Wrk_TargetNum := Wrk_NumEligible;]]></Line>
      <Line Number="257"><![CDATA[END_IF;]]></Line>
      <Line Number="258"><![CDATA[IF Wrk_TargetNum < 0 THEN]]></Line>
      <Line Number="259"><![CDATA[    Wrk_TargetNum := 0;]]></Line>
      <Line Number="260"><![CDATA[END_IF;]]></Line>
      <Line Number="261"><![CDATA[IF NOT Wrk_SysRunning THEN]]></Line>
      <Line Number="262"><![CDATA[    Wrk_TargetNum := 0;]]></Line>
      <Line Number="263"><![CDATA[END_IF;]]></Line>
      <Line Number="264"><![CDATA[]]></Line>
      <Line Number="265"><![CDATA[]]></Line>
      <Line Number="266"><![CDATA[(*]]></Line>
      <Line Number="267"><![CDATA[========================================]]></Line>
      <Line Number="268"><![CDATA[Per-unit staggered enrollment - Wrk_CmdRunMask persists which units are
currently committed to run (bit i = unit i). At most one unit is added
(Cfg_StartDelay elapsed) or removed (Cfg_StopDelay elapsed) per timer
interval, so a promoted standby staggers in exactly like a fresh start
even when the overall running count doesn't change (e.g. a fault swap
keeps the demand-driven headcount the same while substituting which
unit fills it). A committed unit that becomes fully ineligible (fault/
disabled) drops immediately, bypassing the stop delay.
Set Cfg_StartDelay = Cfg_StopDelay = 0 for immediate response.]]></Line>
      <Line Number="271"><![CDATA[========================================]]></Line>
      <Line Number="272"><![CDATA[*)]]></Line>
      <Line Number="273"><![CDATA[Wrk_StaggerTmrDNEdge := Wrk_StaggerTmr.DN AND NOT Wrk_PrevStaggerTmrDN;
Wrk_PrevStaggerTmrDN := Wrk_StaggerTmr.DN;]]></Line>
      <Line Number="275"><![CDATA[]]></Line>
      <Line Number="276"><![CDATA[(* Units that should be running now, and immediate drop of anything
   that's no longer eligible at all (no stop-delay wait for a fault) *)
Wrk_DesiredRunMask := 0;
FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO
    IF Ref_Units[Wrk_I].Val_Rank > 0 AND Ref_Units[Wrk_I].Val_Rank <= Wrk_TargetNum THEN
        Wrk_DesiredRunMask.[Wrk_I] := 1;
    END_IF;
    IF Wrk_CmdRunMask.[Wrk_I] AND (NOT Wrk_UnitEligible.[Wrk_I]) THEN
        Wrk_CmdRunMask.[Wrk_I] := 0;
    END_IF;
END_FOR;]]></Line>
      <Line Number="278"><![CDATA[]]></Line>
      <Line Number="279"><![CDATA[(* Pick the single highest-priority pending add / lowest-priority
   pending removal so at most one unit changes state per interval *)
Wrk_PendingAdd    := -1;
Wrk_PendingRemove := -1;
FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO
    IF Wrk_DesiredRunMask.[Wrk_I] AND (NOT Wrk_CmdRunMask.[Wrk_I]) THEN
        IF Wrk_PendingAdd < 0 THEN
            Wrk_PendingAdd := Wrk_I;
        ELSIF Ref_Units[Wrk_I].Val_Rank < Ref_Units[Wrk_PendingAdd].Val_Rank THEN
            Wrk_PendingAdd := Wrk_I;
        END_IF;
    END_IF;
    IF Wrk_CmdRunMask.[Wrk_I] AND (NOT Wrk_DesiredRunMask.[Wrk_I]) THEN
        IF Wrk_PendingRemove < 0 THEN
            Wrk_PendingRemove := Wrk_I;
        ELSIF Ref_Units[Wrk_I].Val_Rank > Ref_Units[Wrk_PendingRemove].Val_Rank THEN
            Wrk_PendingRemove := Wrk_I;
        END_IF;
    END_IF;
END_FOR;]]></Line>
      <Line Number="281"><![CDATA[]]></Line>
      <Line Number="282"><![CDATA[IF Wrk_PendingAdd >= 0 THEN
    Wrk_StaggerTmr.PRE := Cfg_StartDelay * 1000.0;
ELSIF Wrk_PendingRemove >= 0 THEN
    Wrk_StaggerTmr.PRE := Cfg_StopDelay * 1000.0;
ELSE
    Wrk_StaggerTmr.PRE := 0;
END_IF;]]></Line>
      <Line Number="284"><![CDATA[]]></Line>
      <Line Number="285"><![CDATA[Wrk_StaggerTmr.TimerEnable := (Wrk_PendingAdd >= 0) OR (Wrk_PendingRemove >= 0);
Wrk_StaggerTmr.Reset := (NOT Wrk_StaggerTmr.TimerEnable) OR Wrk_StaggerTmrDNEdge;
TONR(Wrk_StaggerTmr);]]></Line>
      <Line Number="287"><![CDATA[]]></Line>
      <Line Number="288"><![CDATA[(* Commit the pending add/remove once its delay elapses (or immediately
   at 0 delay, snapping every pending unit at once to match the
   documented zero-delay contract) *)
IF Wrk_PendingAdd >= 0 AND (Wrk_StaggerTmrDNEdge OR Cfg_StartDelay <= 0.0) THEN
    IF Cfg_StartDelay <= 0.0 THEN
        FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO
            IF Wrk_DesiredRunMask.[Wrk_I] AND (NOT Wrk_CmdRunMask.[Wrk_I]) THEN
                Wrk_CmdRunMask.[Wrk_I] := 1;
            END_IF;
        END_FOR;
    ELSE
        Wrk_CmdRunMask.[Wrk_PendingAdd] := 1;
    END_IF;
ELSIF Wrk_PendingRemove >= 0 AND (Wrk_StaggerTmrDNEdge OR Cfg_StopDelay <= 0.0) THEN
    IF Cfg_StopDelay <= 0.0 THEN
        FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO
            IF Wrk_CmdRunMask.[Wrk_I] AND (NOT Wrk_DesiredRunMask.[Wrk_I]) THEN
                Wrk_CmdRunMask.[Wrk_I] := 0;
            END_IF;
        END_FOR;
    ELSE
        Wrk_CmdRunMask.[Wrk_PendingRemove] := 0;
    END_IF;
END_IF;]]></Line>
      <Line Number="305"><![CDATA[]]></Line>
      <Line Number="306"><![CDATA[(*
========================================
Issue per-unit PCmd_Start / PCmd_Stop from the committed run mask, and
report Wrk_EffectiveTarget as the count currently committed.
========================================
*)
Wrk_EffectiveTarget := 0;
FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO
    IF Wrk_CmdRunMask.[Wrk_I] THEN
        Ref_Units[Wrk_I].PCmd_Start := 1;
        Ref_Units[Wrk_I].PCmd_Stop  := 0;
        Wrk_EffectiveTarget := Wrk_EffectiveTarget + 1;
    ELSE
        Ref_Units[Wrk_I].PCmd_Start := 0;
        Ref_Units[Wrk_I].PCmd_Stop  := 1;
    END_IF;
END_FOR;]]></Line>
      <Line Number="322"><![CDATA[]]></Line>
      <Line Number="323"><![CDATA[]]></Line>
      <Line Number="324"><![CDATA[(*]]></Line>
      <Line Number="325"><![CDATA[========================================]]></Line>
      <Line Number="326"><![CDATA[Per-unit status rollup bitmasks (bit i = unit i)]]></Line>
      <Line Number="327"><![CDATA[========================================]]></Line>
      <Line Number="328"><![CDATA[*)]]></Line>
      <Line Number="329"><![CDATA[Sts_UnitAvail    := 0;]]></Line>
      <Line Number="330"><![CDATA[Sts_UnitRunning  := 0;]]></Line>
      <Line Number="331"><![CDATA[Sts_UnitStarting := 0;]]></Line>
      <Line Number="332"><![CDATA[Sts_UnitStopping := 0;]]></Line>
      <Line Number="333"><![CDATA[Sts_UnitStopped  := 0;]]></Line>
      <Line Number="334"><![CDATA[Wrk_NumRunning   := 0;]]></Line>
      <Line Number="335"><![CDATA[]]></Line>
      <Line Number="336"><![CDATA[FOR Wrk_I := 0 TO Wrk_ClampedNumUnits - 1 DO]]></Line>
      <Line Number="337"><![CDATA[    IF Wrk_UnitEligible.[Wrk_I] THEN]]></Line>
      <Line Number="338"><![CDATA[        Sts_UnitAvail.[Wrk_I] := 1;]]></Line>
      <Line Number="339"><![CDATA[    END_IF;]]></Line>
      <Line Number="340"><![CDATA[    IF Ref_Units[Wrk_I].Sts_Running THEN]]></Line>
      <Line Number="341"><![CDATA[        Sts_UnitRunning.[Wrk_I] := 1;]]></Line>
      <Line Number="342"><![CDATA[        Wrk_NumRunning := Wrk_NumRunning + 1;]]></Line>
      <Line Number="343"><![CDATA[    END_IF;]]></Line>
      <Line Number="344"><![CDATA[    IF Ref_Units[Wrk_I].Sts_Starting THEN]]></Line>
      <Line Number="345"><![CDATA[        Sts_UnitStarting.[Wrk_I] := 1;]]></Line>
      <Line Number="346"><![CDATA[    END_IF;]]></Line>
      <Line Number="347"><![CDATA[    IF Ref_Units[Wrk_I].Sts_Stopping THEN]]></Line>
      <Line Number="348"><![CDATA[        Sts_UnitStopping.[Wrk_I] := 1;]]></Line>
      <Line Number="349"><![CDATA[    END_IF;]]></Line>
      <Line Number="350"><![CDATA[    IF Ref_Units[Wrk_I].Sts_Stopped THEN]]></Line>
      <Line Number="351"><![CDATA[        Sts_UnitStopped.[Wrk_I] := 1;]]></Line>
      <Line Number="352"><![CDATA[    END_IF;]]></Line>
      <Line Number="353"><![CDATA[END_FOR;]]></Line>
      <Line Number="354"><![CDATA[]]></Line>
      <Line Number="355"><![CDATA[]]></Line>
      <Line Number="356"><![CDATA[(*]]></Line>
      <Line Number="357"><![CDATA[========================================]]></Line>
      <Line Number="358"><![CDATA[System-level statuses]]></Line>
      <Line Number="359"><![CDATA[========================================]]></Line>
      <Line Number="360"><![CDATA[*)]]></Line>
      <Line Number="361"><![CDATA[Sts_Prog       := Wrk_ModeAuto;]]></Line>
      <Line Number="362"><![CDATA[Sts_Oper       := NOT Wrk_ModeAuto;]]></Line>
      <Line Number="363"><![CDATA[Sts_NotRdy     := Wrk_NotRdy;]]></Line>
      <Line Number="364"><![CDATA[Sts_Available  := Sts_Prog AND NOT Sts_NotRdy;]]></Line>
      <Line Number="365"><![CDATA[Sts_Ready      := NOT (Alm_CfgErr OR Alm_IntlkTrip);]]></Line>
      <Line Number="366"><![CDATA[Sts_RdyReset   := Alm_CfgErr OR Alm_IntlkTrip;]]></Line>
      <Line Number="367"><![CDATA[]]></Line>
      <Line Number="368"><![CDATA[(* System-level state matches PlantPAx P_LLS convention:]]></Line>
      <Line Number="369"><![CDATA[   - Sts_Running mirrors the system command latch, not physical unit motion.]]></Line>
      <Line Number="370"><![CDATA[   - Sts_Stopped / Sts_Stopping only meaningful when system commanded off.]]></Line>
      <Line Number="371"><![CDATA[   - Sts_Increasing / Sts_Decreasing compare actual running count to demand,]]></Line>
      <Line Number="372"><![CDATA[     not internal target ramp - so they stay TRUE until units physically catch up. *)]]></Line>
      <Line Number="373"><![CDATA[Val_Demand := Wrk_EffectiveTarget;]]></Line>
      <Line Number="374"><![CDATA[]]></Line>
      <Line Number="375"><![CDATA[IF Wrk_SysRunning THEN]]></Line>
      <Line Number="376"><![CDATA[    Sts_Running    := 1;]]></Line>
      <Line Number="377"><![CDATA[    Sts_Stopped    := 0;]]></Line>
      <Line Number="378"><![CDATA[    Sts_Stopping   := 0;]]></Line>
      <Line Number="379"><![CDATA[    Sts_Increasing := Wrk_NumRunning < Val_Demand;]]></Line>
      <Line Number="380"><![CDATA[    Sts_Decreasing := Wrk_NumRunning > Val_Demand;]]></Line>
      <Line Number="381"><![CDATA[ELSE]]></Line>
      <Line Number="382"><![CDATA[    Sts_Running    := 0;]]></Line>
      <Line Number="383"><![CDATA[    Sts_Stopped    := Wrk_NumRunning = 0;]]></Line>
      <Line Number="384"><![CDATA[    Sts_Stopping   := Wrk_NumRunning > 0;]]></Line>
      <Line Number="385"><![CDATA[    Sts_Increasing := 0;]]></Line>
      <Line Number="386"><![CDATA[    Sts_Decreasing := 0;]]></Line>
      <Line Number="387"><![CDATA[END_IF;]]></Line>
      <Line Number="388"><![CDATA[]]></Line>
      <Line Number="389"><![CDATA[Val_NumRunning   := Wrk_NumRunning;]]></Line>
      <Line Number="390"><![CDATA[Val_NumAvailable := Wrk_NumEligible;]]></Line>
      <Line Number="391"><![CDATA[Val_RotateOffset := Wrk_RotateOffset;]]></Line>
</STContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
</AddOnInstructionDefinitions>
<Dependencies>
<Dependency Type="DataType" Name="IOC_LLS_Unit"/>
</Dependencies>
</Controller>
</RSLogix5000Content>
